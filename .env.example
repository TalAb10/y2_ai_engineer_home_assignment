# Copy to .env and fill in real values — never commit .env

# --- Required ---
OPENAI_API_KEY=sk-...

# --- Optional overrides (defaults shown) ---
LLM_MODEL=gpt-5-mini
LLM_ENABLED=true
LLM_TIMEOUT_S=20.0
LLM_MAX_RETRIES=1
PATTERN_COVERAGE_THRESHOLD=0.90
MAX_INPUT_CHARS=512
CACHE_SIZE=10000
LOG_LEVEL=INFO
